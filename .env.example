# Fastpayment - copy to .env.dev for local development
# Database (required)
DATABASE_URL=postgresql+asyncpg://fastpayment:fastpayment@db:5432/fastpayment_dev

# Environment
ENVIRONMENT=development
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Prometheus (set true to enable /metrics)
PROMETHEUS_ENABLED=false

# Logging
LOG_LEVEL=DEBUG
